{
  "mcpServers": {
    "clickup": {
      "args": [
        "-y",
        "@taazkareem/clickup-mcp-server"
      ],
      "command": "npx",
      "env": {
        "CLICKUP_API_KEY": "${env:CLICKUP_KEY}"
      }
    },
    "gmail": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-gmail"
      ],
      "command": "npx",
      "env": {
        "GMAIL_CREDENTIALS": "${env:GMAIL_CREDS}"
      }
    },
    "google-calendar": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-calendar"
      ],
      "command": "npx",
      "env": {
        "GOOGLE_CALENDAR_TOKEN": "${env:GOOGLE_CALENDAR_TOKEN}"
      }
    },
    "slack": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "command": "npx",
      "env": {
        "SLACK_BOT_TOKEN": "${env:SLACK_TOKEN}",
        "SLACK_DEFAULT_CHANNEL": "${env:SLACK_CHANNEL}"
      }
    }
  }
}
