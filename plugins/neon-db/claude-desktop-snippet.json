{
  "_comment": "Paste the \"mcpServers\" entries below into your claude_desktop_config.json",
  "_plugin": "neon-db",
  "_version": "1.0.0",
  "mcpServers": {
    "postgres": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "command": "npx",
      "env": {
        "DATABASE_URL": "${NEON_DATABASE_URL}"
      }
    }
  }
}
