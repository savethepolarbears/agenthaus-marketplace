{
  "name": "neon-db",
  "version": "1.0.0",
  "description": "Interact with Neon serverless Postgres databases.",
  "author": "AgentHaus Team",
  "homepage": "https://github.com/savethepolarbears/agenthaus-marketplace",
  "license": "MIT",
  "tags": ["database", "postgres", "serverless"],
  "commands": [
    "./commands/query.md"
  ],
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${NEON_DATABASE_URL}"
      }
    }
  }
}
