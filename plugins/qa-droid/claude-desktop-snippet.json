{
  "_comment": "Paste the \"mcpServers\" entries below into your claude_desktop_config.json",
  "_plugin": "qa-droid",
  "_version": "2.1.0",
  "mcpServers": {
    "gmail": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-gmail"
      ],
      "command": "npx",
      "env": {
        "GMAIL_CREDENTIALS": "${GMAIL_CREDS}"
      }
    },
    "playwright-local": {
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/index.js"
      ],
      "command": "node"
    },
    "slack": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "command": "npx",
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_TOKEN}",
        "SLACK_DEFAULT_CHANNEL": "${SLACK_CHANNEL}"
      }
    }
  }
}
