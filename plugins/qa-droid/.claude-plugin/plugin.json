{
  "name": "qa-droid",
  "version": "2.1.0",
  "description": "Automated Playwright tests with Slack/Gmail notifications.",
  "author": "AgentHaus Team",
  "homepage": "https://github.com/savethepolarbears/agenthaus-marketplace",
  "license": "MIT",
  "tags": ["testing", "qa", "notifications"],
  "agents": [
    "./agents/sdet-agent.md"
  ],
  "mcpServers": {
    "playwright-local": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/index.js"]
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_TOKEN}",
        "SLACK_DEFAULT_CHANNEL": "${SLACK_CHANNEL}"
      }
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gmail"],
      "env": {
        "GMAIL_CREDENTIALS": "${GMAIL_CREDS}"
      }
    }
  }
}
