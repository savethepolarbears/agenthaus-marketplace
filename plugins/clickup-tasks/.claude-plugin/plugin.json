{
  "name": "clickup-tasks",
  "version": "1.0.0",
  "description": "Manage ClickUp tasks, lists and time tracking.",
  "author": "AgentHaus Team",
  "homepage": "https://github.com/savethepolarbears/agenthaus-marketplace",
  "license": "MIT",
  "tags": ["productivity", "task-management"],
  "mcpServers": {
    "clickup": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-clickup"],
      "env": {
        "CLICKUP_API_KEY": "${CLICKUP_API_KEY}"
      }
    }
  }
}
