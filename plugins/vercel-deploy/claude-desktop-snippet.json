{
  "_comment": "Paste the \"mcpServers\" entries below into your claude_desktop_config.json",
  "_plugin": "vercel-deploy",
  "_version": "1.0.0",
  "mcpServers": {
    "vercel": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-vercel"
      ],
      "command": "npx",
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    }
  }
}
