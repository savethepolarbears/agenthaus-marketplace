{
  "_comment": "Paste the \"mcpServers\" entries below into your claude_desktop_config.json",
  "_plugin": "context7-docs",
  "_version": "1.0.0",
  "mcpServers": {
    "context7": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-context7"
      ],
      "command": "npx",
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
