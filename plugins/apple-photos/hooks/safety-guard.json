{
  "description": "Log osxphotos write operations for safety audit trail. Captures batch-edit, timewarp, push-exif, import, and add-locations invocations.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apple-photos:(metadata|fix-dates|fix-locations|import)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] apple-photos write operation executed\" >> \"$CLAUDE_PROJECT_DIR/apple_photos_audit.log\""
          }
        ]
      }
    ]
  }
}
