{
  "description": "Safety guard for destructive Apple operations and audit logging for all mutations.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__apple-productivity__(notes_delete|notes_delete_folder|reminders_delete|reminder_list_delete)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/confirm-destructive.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apple-workflows:(notes|reminders|shortcuts|capture|organize|daily-review)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] apple-workflows command: $TOOL_NAME\" >> \"$CLAUDE_PROJECT_DIR/apple_workflows_audit.log\""
          }
        ]
      }
    ]
  }
}
