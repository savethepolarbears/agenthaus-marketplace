# AgentHaus Environment Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# CLOUD PLATFORMS
# =============================================================================

# Cloudflare (for cloudflare-platform and devops-flow plugins)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Vercel (for vercel-deploy plugin)
VERCEL_TOKEN=

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# GitHub (for github-integration and devops-flow plugins)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# =============================================================================
# PRODUCTIVITY TOOLS
# =============================================================================

# Notion (for notion-workspace and knowledge-synapse plugins)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ClickUp (for clickup-tasks and task-commander plugins)
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=

# Slack (for devops-flow, qa-droid, and task-commander plugins)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# Gmail (for task-commander and qa-droid plugins)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Google Calendar (for task-commander plugin)
GOOGLE_CALENDAR_ID=

# Google Drive (for knowledge-synapse plugin)
GOOGLE_DRIVE_FOLDER_ID=

# =============================================================================
# DATABASES
# =============================================================================

# Neon/Postgres (for neon-db and data-core plugins)
DATABASE_URL=
NEON_API_KEY=

# =============================================================================
# DOCUMENTATION
# =============================================================================

# Context7 (for context7-docs and knowledge-synapse plugins)
# No API key required - uses public API

# =============================================================================
# TESTING
# =============================================================================

# Playwright (for playwright-testing and qa-droid plugins)
# No credentials required - uses local browser

# =============================================================================
# WEB APPLICATION
# =============================================================================

# Next.js (for agenthaus-web)
NEXT_PUBLIC_API_URL=http://localhost:3000
